DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Log threshold for our apps (data, feature, chart). DEBUG also surfaces
# per-URL plumbing details from the archive backfills.
DJANGO_LOG_LEVEL=INFO

# Worker count for the Binance metrics-archive parallel daily fetcher.
# Binance publishes no monthly metrics ZIPs, so a 1-year OI backfill is
# fundamentally 365 HTTP requests; this knob controls how many of them
# run concurrently. Default 8; bounded to [1, 32].
BINANCE_ARCHIVE_CONCURRENCY=8

POSTGRES_DB=liquidation_trading
POSTGRES_USER=liquidation_trading
POSTGRES_PASSWORD=liquidation_trading
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/1
